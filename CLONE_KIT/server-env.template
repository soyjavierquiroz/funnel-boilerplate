CAPTURE_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CAPTURE_ADS_WEBHOOK_URL=https://crm.example.com/webhook/ads
CAPTURE_ORGANIC_WEBHOOK_URL=https://crm.example.com/webhook/organic
