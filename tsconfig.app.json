{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": [
    "src/components/common/video-player/dist",
    "src/components/common/video-player/node_modules",
    "src/components/common/video-player/public",
    "src/components/common/video-player/src/App.tsx",
    "src/components/common/video-player/src/main.tsx",
    "src/components/common/video-player/vite.config.ts",
    "src/components/themes/expert/components/video-player/dist",
    "src/components/themes/expert/components/video-player/node_modules",
    "src/components/themes/expert/components/video-player/public",
    "src/components/themes/expert/components/video-player/src/App.tsx",
    "src/components/themes/expert/components/video-player/src/main.tsx",
    "src/components/themes/expert/components/video-player/vite.config.ts"
  ]
}
